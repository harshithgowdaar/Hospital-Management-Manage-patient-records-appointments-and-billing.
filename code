# ── DASHBOARD ──────────────────────────────
class DashboardPage(BasePage):
    def __init__(self, master, app):
        super().__init__(master)
        self.app = app
        self._build()

    def _build(self):
        # header
        hdr = tk.Frame(self, bg=BG)
        hdr.pack(fill="x", padx=30, pady=(28,0))
        tk.Label(hdr, text="Dashboard", fg=TEXT, bg=BG, font=FONT_TITLE).pack(side="left")
        self.date_lbl = tk.Label(hdr, text="", fg=MUTED, bg=BG, font=FONT_SMALL)
        self.date_lbl.pack(side="right", pady=10)
        self._tick()

        tk.Frame(self, bg=BORDER, height=1).pack(fill="x", padx=30, pady=12)

        # stat cards
        self.stats_frame = tk.Frame(self, bg=BG)
        self.stats_frame.pack(fill="x", padx=30, pady=4)

        # recent activity
        act_lbl = tk.Frame(self, bg=BG)
        act_lbl.pack(fill="x", padx=30, pady=(18,4))
        tk.Label(act_lbl, text="Recent Patients", fg=MUTED, bg=BG, font=FONT_LABEL).pack(side="left")

        table_frame, self.tree = make_table(self, ("ID","Name","Age","Disease","Doctor","Registered"))
        table_frame.pack(fill="both", expand=True, padx=30, pady=(0,20))

        cols = [("ID",70),("Name",160),("Age",50),("Disease",160),("Doctor",160),("Registered",140)]
        for col, w in cols:
            self.tree.heading(col, text=col)
            self.tree.column(col, width=w, anchor="center" if col in ("ID","Age") else "w")

    def _tick(self):
        self.date_lbl.config(text=datetime.now().strftime("%A, %d %B %Y  |  %H:%M:%S"))
        self.after(1000, self._tick)

    def _stat_card(self, parent, label, value, color):
        c = tk.Frame(parent, bg=CARD, padx=20, pady=16)
        c.pack(side="left", expand=True, fill="both", padx=6)
        tk.Frame(c, bg=color, height=3).pack(fill="x", pady=(0,10))
        tk.Label(c, text=str(value), fg=color, bg=CARD, font=("Georgia",28,"bold")).pack()
        tk.Label(c, text=label, fg=MUTED, bg=CARD, font=FONT_SMALL).pack()

    def refresh(self):
        p = self.app.patients
        a = self.app.appointments
        b = self.app.billing

        for w in self.stats_frame.winfo_children():
            w.destroy()

        revenue  = sum(v["total"] for v in b.values() if v.get("paid"))
        self._stat_card(self.stats_frame, "Total Patients",     len(p),    ACCENT)
        self._stat_card(self.stats_frame, "Appointments",       len(a),    ACCENT2)
        self._stat_card(self.stats_frame, "Bills Generated",    len(b),    WARNING)
        self._stat_card(self.stats_frame, f"Revenue (₹)",       f"{revenue:,.0f}", SUCCESS)

        for row in self.tree.get_children():
            self.tree.delete(row)
        for pid, info in list(p.items())[-10:]:
            self.tree.insert("", 0, values=(pid, info["name"], info["age"],
                                             info["disease"], info["doctor"],
                                             info.get("registered_on","")))

