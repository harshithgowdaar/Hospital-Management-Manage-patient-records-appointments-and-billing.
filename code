        logo.pack(fill="x", pady=20, padx=16)
        tk.Label(logo, text="✚", fg=ACCENT, bg=CARD, font=("Georgia",28)).pack()
        tk.Label(logo, text="MedSys", fg=TEXT, bg=CARD, font=("Georgia",15,"bold")).pack()
