# ─────────────────────────────────────────────
#  DATA HELPERS
# ─────────────────────────────────────────────
def load_data(fp):
    try:
        if os.path.exists(fp):
            with open(fp) as f:
                return json.load(f)
    except Exception:
        pass
    return {}

def save_data(fp, data):
    with open(fp, "w") as f:
        json.dump(data, f, indent=4)

def next_pid(patients):
    return f"P{len(patients)+1:03d}"

# ─────────────────────────────────────────────
#  REUSABLE WIDGETS
# ─────────────────────────────────────────────
def make_card(parent, **kwargs):
    return tk.Frame(parent, bg=CARD, bd=0, relief="flat", **kwargs)

def styled_label(parent, text, fg=TEXT, font=FONT_BODY, bg=CARD, **kw):
    return tk.Label(parent, text=text, fg=fg, bg=bg, font=font, **kw)

def styled_entry(parent, width=28, show=None):
    e = tk.Entry(parent, width=width, bg=CARD2, fg=TEXT, insertbackground=ACCENT,
                 relief="flat", bd=0, font=FONT_BODY, highlightthickness=1,
                 highlightcolor=ACCENT, highlightbackground=BORDER, show=show or "")
    e.configure(disabledbackground=CARD2, disabledforeground=MUTED)
    return e

def accent_btn(parent, text, cmd, color=ACCENT, width=18):
    btn = tk.Button(parent, text=text, command=cmd,
                    bg=color, fg=BG, font=FONT_BTN,
                    activebackground=CARD2, activeforeground=TEXT,
                    relief="flat", bd=0, cursor="hand2",
                    padx=10, pady=6, width=width)
    btn.bind("<Enter>", lambda e: btn.config(bg=TEXT if color==ACCENT else ACCENT))
    btn.bind("<Leave>", lambda e: btn.config(bg=color))
    return btn

def ghost_btn(parent, text, cmd, width=18):
    btn = tk.Button(parent, text=text, command=cmd,
                    bg=CARD, fg=MUTED, font=FONT_BTN,
                    activebackground=CARD2, activeforeground=TEXT,
                    relief="flat", bd=0, cursor="hand2",
                    padx=10, pady=6, width=width,
                    highlightthickness=1, highlightbackground=BORDER,
                    highlightcolor=ACCENT)
    btn.bind("<Enter>", lambda e: btn.config(fg=TEXT, highlightbackground=ACCENT))
    btn.bind("<Leave>", lambda e: btn.config(fg=MUTED, highlightbackground=BORDER))
    return btn

def section_sep(parent, bg=CARD):
    tk.Frame(parent, bg=BORDER, height=1).pack(fill="x", padx=16, pady=8)

def make_table(parent, columns, bg=CARD):
    style = ttk.Style()
    style.theme_use("clam")
    style.configure("Hospital.Treeview",
                    background=CARD2, foreground=TEXT,
                    fieldbackground=CARD2, font=FONT_SMALL,
                    rowheight=28, borderwidth=0)
    style.configure("Hospital.Treeview.Heading",
                    background=CARD, foreground=ACCENT,
                    font=FONT_LABEL, borderwidth=0, relief="flat")
    style.map("Hospital.Treeview",
              background=[("selected", ACCENT)],
              foreground=[("selected", BG)])
    style.map("Hospital.Treeview.Heading", relief=[("active","flat")])

    frame = tk.Frame(parent, bg=bg)
    tree  = ttk.Treeview(frame, columns=columns, show="headings",
                         style="Hospital.Treeview")
    vsb = ttk.Scrollbar(frame, orient="vertical", command=tree.yview)
    tree.configure(yscrollcommand=vsb.set)
    vsb.pack(side="right", fill="y")
    tree.pack(fill="both", expand=True)
    return frame, tree

