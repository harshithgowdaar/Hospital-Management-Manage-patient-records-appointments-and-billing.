]

class PatientsPage(BasePage):
    def __init__(self, master, app):
        super().__init__(master)
        self.app = app
        self._build()

    def _build(self):
        hdr = tk.Frame(self, bg=BG)
        hdr.pack(fill="x", padx=30, pady=(28,0))
        tk.Label(hdr, text="Patients", fg=TEXT, bg=BG, font=FONT_TITLE).pack(side="left")
        accent_btn(hdr, "+ Register Patient", self._add, width=20).pack(side="right", pady=8)

        tk.Frame(self, bg=BORDER, height=1).pack(fill="x", padx=30, pady=10)

        # search
        sf = tk.Frame(self, bg=BG)
        sf.pack(fill="x", padx=30, pady=(0,10))
        tk.Label(sf, text="🔍", fg=MUTED, bg=BG, font=FONT_BODY).pack(side="left")
        self.search_var = tk.StringVar()
        self.search_var.trace("w", lambda *_: self.refresh())
        se = tk.Entry(sf, textvariable=self.search_var, width=36,
                      bg=CARD, fg=TEXT, insertbackground=ACCENT,
                      relief="flat", font=FONT_BODY, bd=0,
                      highlightthickness=1, highlightbackground=BORDER, highlightcolor=ACCENT)
        se.pack(side="left", padx=8, ipady=5)

        frame, self.tree = make_table(self, ("ID","Name","Age","Gender","Contact","Disease","Doctor"))
        frame.pack(fill="both", expand=True, padx=30)

        cols = [("ID",60),("Name",150),("Age",45),("Gender",70),
                ("Contact",110),("Disease",150),("Doctor",150)]
        for col, w in cols:
            self.tree.heading(col, text=col)
            self.tree.column(col, width=w)

        # action buttons
        bf = tk.Frame(self, bg=BG)
        bf.pack(fill="x", padx=30, pady=10)
        ghost_btn(bf, "✏  Edit",   self._edit,   width=14).pack(side="left", padx=4)
        ghost_btn(bf, "🗑  Delete", self._delete, width=14).pack(side="left", padx=4)

    def _selected_pid(self):
        sel = self.tree.selection()
        return self.tree.item(sel[0])["values"][0] if sel else None

    def _add(self):
        FormDialog(self.master, "Register Patient", PATIENT_FIELDS, self._do_add)

    def _do_add(self, data):
        if not data.get("name"):
            messagebox.showerror("Error","Name is required.")
            return
        try: int(data["age"])
        except: messagebox.showerror("Error","Age must be a number."); return
        pid = next_pid(self.app.patients)
        self.app.patients[pid] = {**data, "age": int(data["age"]),
                                   "registered_on": datetime.now().strftime("%Y-%m-%d %H:%M")}
        save_data(PATIENTS_FILE, self.app.patients)
        self.app.refresh_all()
        messagebox.showinfo("Success", f"Patient registered as {pid}")

    def _edit(self):
        pid = self._selected_pid()
        if not pid: messagebox.showwarning("Select","Please select a patient."); return
        info = self.app.patients[pid]
        FormDialog(self.master, f"Edit Patient — {pid}", PATIENT_FIELDS,
                   lambda d: self._do_edit(pid, d), prefill=info)

    def _do_edit(self, pid, data):
        self.app.patients[pid].update(data)
        save_data(PATIENTS_FILE, self.app.patients)
        self.app.refresh_all()

    def _delete(self):
        pid = self._selected_pid()
        if not pid: messagebox.showwarning("Select","Please select a patient."); return
        name = self.app.patients[pid]["name"]
        if messagebox.askyesno("Confirm", f"Delete patient {name} ({pid}) and all related records?"):
            self.app.patients.pop(pid, None)
            self.app.appointments.pop(pid, None)
            self.app.billing.pop(pid, None)
            save_data(PATIENTS_FILE, self.app.patients)
            save_data(APPOINTMENTS_FILE, self.app.appointments)
            save_data(BILLING_FILE, self.app.billing)
            self.app.refresh_all()

    def refresh(self):
        kw = self.search_var.get().lower()
        for row in self.tree.get_children():
            self.tree.delete(row)
        for pid, p in self.app.patients.items():
            if kw and kw not in pid.lower() and kw not in p["name"].lower():
                continue
            self.tree.insert("", "end", values=(pid, p["name"], p["age"],
                                                 p.get("gender",""), p.get("contact",""),
                                                 p.get("disease",""), p.get("doctor","")))

# ── APPOINTMENTS ───────────────────────────
class AppointmentsPage(BasePage):
    def __init__(self, master, app):
        super().__init__(master)
        self.app = app
        self._build()

    def _build(self):
        hdr = tk.Frame(self, bg=BG)
        hdr.pack(fill="x", padx=30, pady=(28,0))
        tk.Label(hdr, text="Appointments", fg=TEXT, bg=BG, font=FONT_TITLE).pack(side="left")
        accent_btn(hdr, "+ Book Appointment", self._book, width=22).pack(side="right", pady=8)

        tk.Frame(self, bg=BORDER, height=1).pack(fill="x", padx=30, pady=10)

        frame, self.tree = make_table(self, ("PID","Patient","Doctor","Date","Time","Status"))
        frame.pack(fill="both", expand=True, padx=30)

        cols = [("PID",60),("Patient",160),("Doctor",160),("Date",110),("Time",80),("Status",110)]
        for col, w in cols:
            self.tree.heading(col, text=col)
            self.tree.column(col, width=w)

        bf = tk.Frame(self, bg=BG)
        bf.pack(fill="x", padx=30, pady=10)
        ghost_btn(bf, "✕  Cancel Appt", self._cancel, width=18).pack(side="left", padx=4)

    def _book(self):
        if not self.app.patients:
            messagebox.showwarning("No Patients","Register a patient first.")
            return
        pid_list = list(self.app.patients.keys())
        fields = [
            ("Patient ID", "pid", "combo", pid_list),
            ("Date (YYYY-MM-DD)", "date"),
            ("Time (HH:MM)",      "time"),
        ]
        FormDialog(self.master, "Book Appointment", fields, self._do_book)

    def _do_book(self, data):
        pid  = data.get("pid","").strip()
        date = data.get("date","").strip()
        time = data.get("time","").strip()
        if pid not in self.app.patients:
            messagebox.showerror("Error","Patient not found."); return
        slot   = f"{date} {time}"
        doctor = self.app.patients[pid]["doctor"]
        for ep, ea in self.app.appointments.items():
            if ea.get("slot") == slot and ea.get("doctor") == doctor:
                messagebox.showerror("Conflict", f"Dr. {doctor} is already booked at {slot}.")
                return
        self.app.appointments[pid] = {
            "patient_name": self.app.patients[pid]["name"],
            "doctor": doctor, "slot": slot, "status": "Scheduled"
        }
        save_data(APPOINTMENTS_FILE, self.app.appointments)
        self.app.refresh_all()
        messagebox.showinfo("Booked", f"Appointment scheduled for {self.app.patients[pid]['name']}.")

    def _cancel(self):
        sel = self.tree.selection()
        if not sel: messagebox.showwarning("Select","Select an appointment."); return
        pid = self.tree.item(sel[0])["values"][0]
        if pid in self.app.appointments:
            self.app.appointments[pid]["status"] = "Cancelled"
            save_data(APPOINTMENTS_FILE, self.app.appointments)
            self.app.refresh_all()

    def refresh(self):
        for row in self.tree.get_children():
            self.tree.delete(row)
        for pid, a in self.app.appointments.items():
            slot_parts = a.get("slot","").split(" ")
            date = slot_parts[0] if len(slot_parts)>0 else ""
            time = slot_parts[1] if len(slot_parts)>1 else ""
            tag  = "cancelled" if a["status"]=="Cancelled" else ""
            iid  = self.tree.insert("", "end", values=(pid, a["patient_name"],
                                                         a["doctor"], date, time, a["status"]), tags=(tag,))
        self.tree.tag_configure("cancelled", foreground=DANGER)

# ── BILLING ────────────────────────────────
class BillingPage(BasePage):
    def __init__(self, master, app):
        super().__init__(master)
        self.app = app
        self._build()

    def _build(self):
        hdr = tk.Frame(self, bg=BG)
        hdr.pack(fill="x", padx=30, pady=(28,0))
        tk.Label(hdr, text="Billing", fg=TEXT, bg=BG, font=FONT_TITLE).pack(side="left")
        accent_btn(hdr, "+ Generate Bill", self._gen, width=20).pack(side="right", pady=8)

        tk.Frame(self, bg=BORDER, height=1).pack(fill="x", padx=30, pady=10)

        frame, self.tree = make_table(self, ("PID","Patient","Doctor","Consult","Medicine","Tests","Total","Status"))
        frame.pack(fill="both", expand=True, padx=30)

        cols = [("PID",55),("Patient",140),("Doctor",130),("Consult",80),
                ("Medicine",80),("Tests",70),("Total",90),("Status",80)]
        for col, w in cols:
            self.tree.heading(col, text=col)
            self.tree.column(col, width=w, anchor="e" if col in ("Consult","Medicine","Tests","Total") else "w")

        bf = tk.Frame(self, bg=BG)
        bf.pack(fill="x", padx=30, pady=10)
        accent_btn(bf, "✓  Mark Paid", self._mark_paid, color=SUCCESS, width=16).pack(side="left", padx=4)
        ghost_btn(bf,  "🖨  Print Bill", self._print,  width=16).pack(side="left", padx=4)

    def _gen(self):
        if not self.app.patients:
            messagebox.showwarning("No Patients","Register a patient first.")
            return
        pid_list = list(self.app.patients.keys())
        fields = [
            ("Patient ID",      "pid",      "combo", pid_list),
            ("Medicine Cost ₹", "medicine"),
            ("Lab / Test Cost ₹","tests"),
        ]
        FormDialog(self.master, "Generate Bill", fields, self._do_gen)

    def _do_gen(self, data):
        pid = data.get("pid","").strip()
        if pid not in self.app.patients:
            messagebox.showerror("Error","Patient not found."); return
        try:
            med   = float(data["medicine"])
            tests = float(data["tests"])
        except:
            messagebox.showerror("Error","Enter valid numeric costs."); return
        total = 500 + med + tests
        self.app.billing[pid] = {
            "patient_name": self.app.patients[pid]["name"],
            "doctor": self.app.patients[pid]["doctor"],
            "consultation_fee": 500,
            "medicine_cost": med, "test_cost": tests,
            "total": total,
            "generated_on": datetime.now().strftime("%Y-%m-%d %H:%M"),
            "paid": False
        }
        save_data(BILLING_FILE, self.app.billing)
        self.app.refresh_all()
        messagebox.showinfo("Bill Created", f"Total: ₹{total:.2f}")

    def _selected(self):
        sel = self.tree.selection()
        return self.tree.item(sel[0])["values"][0] if sel else None

    def _mark_paid(self):
        pid = self._selected()
        if not pid: messagebox.showwarning("Select","Select a bill."); return
        if pid in self.app.billing:
            self.app.billing[pid]["paid"] = True
            save_data(BILLING_FILE, self.app.billing)
            self.app.refresh_all()

    def _print(self):
        pid = self._selected()
        if not pid or pid not in self.app.billing:
            messagebox.showwarning("Select","Select a bill."); return
        b = self.app.billing[pid]
        msg = (
            f"{'='*38}\n"
            f"      ALLIANCE HOSPITAL BILL\n"
            f"{'='*38}\n"
            f"  Patient ID   : {pid}\n"
            f"  Patient Name : {b['patient_name']}\n"
            f"  Doctor       : {b['doctor']}\n"
            f"  Date         : {b['generated_on']}\n"
            f"{'-'*38}\n"
            f"  Consultation : ₹{b['consultation_fee']:>8.2f}\n"
            f"  Medicines    : ₹{b['medicine_cost']:>8.2f}\n"
            f"  Lab / Tests  : ₹{b['test_cost']:>8.2f}\n"
            f"{'-'*38}\n"
            f"  TOTAL        : ₹{b['total']:>8.2f}\n"
            f"  Status       : {'PAID ✓' if b['paid'] else 'UNPAID'}\n"
            f"{'='*38}"
        )
        win = tk.Toplevel(self.master)
        win.title("Bill")
        win.configure(bg=BG)
        win.resizable(False, False)
        win.geometry("340x320")
        tk.Label(win, text=msg, font=("Courier",10), bg=CARD, fg=TEXT,
                 justify="left", padx=16, pady=14).pack(padx=16, pady=16, fill="both")
        accent_btn(win, "Close", win.destroy, width=12).pack(pady=(0,12))

    def refresh(self):
        for row in self.tree.get_children():
            self.tree.delete(row)
        for pid, b in self.app.billing.items():
            tag  = "paid" if b["paid"] else ""
            self.tree.insert("", "end", values=(
                pid, b["patient_name"], b["doctor"],
                f"₹{b['consultation_fee']:.0f}",
                f"₹{b['medicine_cost']:.0f}",
                f"₹{b['test_cost']:.0f}",
                f"₹{b['total']:.2f}",
                "PAID ✓" if b["paid"] else "UNPAID"
            ), tags=(tag,))
        self.tree.tag_configure("paid", foreground=SUCCESS)

