class FormDialog(tk.Toplevel):
    def __init__(self, master, title, fields, on_submit, prefill=None):
        super().__init__(master)
        self.title(title)
        self.configure(bg=BG)
        self.resizable(False, False)
        self.grab_set()

        # center
        self.update_idletasks()
        w, h = 460, 80 + len(fields)*52 + 60
        x = master.winfo_rootx() + (master.winfo_width()-w)//2
        y = master.winfo_rooty() + (master.winfo_height()-h)//2
        self.geometry(f"{w}x{h}+{x}+{y}")

        card = make_card(self)
        card.pack(fill="both", expand=True, padx=16, pady=16)

        styled_label(card, title, fg=ACCENT, font=FONT_HEAD, bg=CARD).pack(pady=(14,4))
        tk.Frame(card, bg=ACCENT, height=2).pack(fill="x", padx=16)

        body = tk.Frame(card, bg=CARD)
        body.pack(fill="both", expand=True, padx=24, pady=10)

        self.entries = {}
        for label, key, *opts in fields:
            row = tk.Frame(body, bg=CARD)
            row.pack(fill="x", pady=4)
            styled_label(row, label, fg=MUTED, font=FONT_SMALL, bg=CARD).pack(anchor="w")
            if opts and opts[0] == "combo":
                var = tk.StringVar()
                cb  = ttk.Combobox(row, textvariable=var, values=opts[1],
                                   font=FONT_BODY, width=38, state="readonly")
                cb.configure()
                cb.pack(fill="x")
                self.entries[key] = var
                if prefill and key in prefill:
                    var.set(prefill[key])
            else:
                e = styled_entry(row, width=44)
                e.pack(fill="x")
                self.entries[key] = e
                if prefill and key in prefill:
                    e.insert(0, str(prefill[key]))

        btn_row = tk.Frame(card, bg=CARD)
        btn_row.pack(pady=(4, 14))
        accent_btn(btn_row, "✓  Submit", lambda: self._submit(fields, on_submit), width=14).pack(side="left", padx=6)
        ghost_btn(btn_row, "✕  Cancel", self.destroy, width=14).pack(side="left", padx=6)

    def _submit(self, fields, on_submit):
        data = {}
        for label, key, *_ in fields:
            val = self.entries[key]
            data[key] = val.get().strip() if isinstance(val, (tk.StringVar, tk.Entry)) else val.get()
        on_submit(data)
        self.destroy()

