#  MAIN APP
# ─────────────────────────────────────────────
class HospitalApp(tk.Tk):
    def __init__(self):
        super().__init__()
        self.title("MedSys — Hospital Management System")
        self.geometry("1100x680")
        self.minsize(900, 600)
        self.configure(bg=BG)

        self.patients     = load_data(PATIENTS_FILE)
        self.appointments = load_data(APPOINTMENTS_FILE)
        self.billing      = load_data(BILLING_FILE)

        # layout
        self.sidebar = Sidebar(self, self._switch)
        self.sidebar.pack(side="left", fill="y")

        tk.Frame(self, bg=BORDER, width=1).pack(side="left", fill="y")

        self.content = tk.Frame(self, bg=BG)
        self.content.pack(side="left", fill="both", expand=True)

        self.pages = {
            "Dashboard"    : DashboardPage(self.content, self),
            "Patients"     : PatientsPage(self.content, self),
            "Appointments" : AppointmentsPage(self.content, self),
            "Billing"      : BillingPage(self.content, self),
        }

        self._current = None
        self.sidebar.select("Dashboard")

    def _switch(self, name):
        if self._current:
            self.pages[self._current].pack_forget()
        self._current = name
        self.pages[name].pack(fill="both", expand=True)
        self.pages[name].refresh()

    def refresh_all(self):
        for page in self.pages.values():
            page.refresh()

if __name__ == "__main__":
    app = HospitalApp()
    app.mainloop()
