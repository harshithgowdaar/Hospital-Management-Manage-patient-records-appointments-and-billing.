PATIENT_FIELDS = [
    ("Full Name",        "name"),
    ("Age",              "age"),
    ("Gender",           "gender", "combo", ["Male","Female","Other"]),
    ("Contact Number",   "contact"),
    ("Disease / Complaint","disease"),
